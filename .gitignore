*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
sdist/
wheels/

# pip
pip-log.txt
pip-delete-this-directory.txt

