# Node.js / Next.js Frontend
# ==============================

node_modules/
.next/
out/

# Package manager locks (keep ONE — remove the others you don't use)
# yarn.lock
# pnpm-lock.yaml

# Build output
frontend/dist/
frontend/.turbo/

# Vercel
.vercel/

