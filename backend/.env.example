# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ezoo_pos

# Application
APP_NAME=EZOO POS
APP_VERSION=1.0.0

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Export limits (FR-040)
CSV_MAX_ROWS=100000
XLSX_MAX_ROWS=50000
PDF_MAX_ROWS=10000

# Rate limiting (FR-039)
EXPORT_RATE_LIMIT_THRESHOLD=5000
EXPORT_RATE_LIMIT_PER_HOUR=10

# Dashboard limits (FR-028)
DASHBOARD_MAX_POINTS=1000

# Performance thresholds (FR-035)
EXPORT_TIMEOUT_SECONDS=30
DASHBOARD_TIMEOUT_SECONDS=3

# Future: Multi-tenancy
# USER_ID=default-user-id
# BRANCH_ID=default-branch-id